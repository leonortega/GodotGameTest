{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "player-state.schema.json",
  "title": "Player State",
  "type": "object",
  "required": [
    "form",
    "invulnerable",
    "invincibilityMode",
    "grounded",
    "canFireProjectile",
    "crouched"
  ],
  "properties": {
    "form": {
      "type": "string",
      "enum": [
        "Small",
        "Super",
        "Fire"
      ]
    },
    "invulnerable": {
      "type": "boolean"
    },
    "invincibilityMode": {
      "type": "string",
      "enum": [
        "none",
        "damage",
        "star"
      ]
    },
    "grounded": {
      "type": "boolean"
    },
    "canFireProjectile": {
      "type": "boolean"
    },
    "crouched": {
      "type": "boolean"
    }
  },
  "additionalProperties": false
}
