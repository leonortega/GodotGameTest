{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "input-map.schema.json",
  "title": "Input Map",
  "type": "object",
  "required": [
    "actions"
  ],
  "properties": {
    "actions": {
      "type": "object",
      "required": [
        "move_left",
        "move_right",
        "move_down",
        "jump",
        "action",
        "pause"
      ],
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "string"
        }
      }
    }
  },
  "additionalProperties": false
}
